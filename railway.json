{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m codegraph_mcp serve --transport streamable-http",
    "healthcheckPath": "/mcp",
    "restartPolicyType": "ON_FAILURE"
  }
}
